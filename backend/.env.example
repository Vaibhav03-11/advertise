# JewelStack Backend Environment Variables
# Copy this to .env and fill in your values

# APK file path (relative to backend directory)
APK_PATH=static/jewelstack.apk

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://jewelstack.app

# Optional: Real gold rate API key (goldapi.io)
GOLD_API_KEY=your_goldapi_key_here

# Optional: Email notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=admin@jewelstack.app
